{
  "$schema": "vscode://schemas/color-theme",
  "name": "Monokai Deuteranopia Colorblind",
  "tokenColors": [
    {
      "settings": {
        "foreground": "#D4E4FF",
        "background": "#0B1026",
        "caret": "#56B4E9",
        "invisibles": "#1E2A4A",
        "lineHighlight": "#121A3A",
        "selection": "#1A2E55",
        "findHighlight": "#F0E442",
        "findHighlightForeground": "#0B1026",
        "selectionBorder": "#1E2A4A",
        "activeGuide": "#56B4E9B0",
        "bracketsForeground": "#D4E4FFA5",
        "bracketsOptions": "underline",
        "bracketContentsForeground": "#D4E4FFA5",
        "bracketContentsOptions": "underline",
        "tagsOptions": "stippled_underline"
      }
    },

    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6B7D94",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment Doc",
      "scope": [
        "comment.block.documentation",
        "comment.block.javadoc"
      ],
      "settings": {
        "foreground": "#7E92AB",
        "fontStyle": "italic"
      }
    },

    {
      "name": "String",
      "scope": "string",
      "settings": {
        "foreground": "#E6C07B"
      }
    },
    {
      "name": "String Quoted Double",
      "scope": [
        "string.quoted.double",
        "string.template.js",
        "string.template.ts",
        "string.template.*"
      ],
      "settings": {
        "foreground": "#E6C07B",
        "fontStyle": "bold"
      }
    },
    {
      "name": "String Quoted Single",
      "scope": "string.quoted.single",
      "settings": {
        "foreground": "#E6C07B",
        "fontStyle": ""
      }
    },
    {
      "name": "String Regex",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#CC79A7"
      }
    },
    {
      "name": "String Escape / Template Expression",
      "scope": [
        "constant.character.escape",
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end"
      ],
      "settings": {
        "foreground": "#D4A0FF"
      }
    },

    {
      "name": "Number",
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#D4A0FF"
      }
    },
    {
      "name": "Built-in Constant (true, false, null)",
      "scope": "constant.language",
      "settings": {
        "foreground": "#D4A0FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "User-defined Constant",
      "scope": [
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#D4A0FF"
      }
    },
    {
      "name": "Constant Variable / Enum Member",
      "scope": [
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#D4A0FF",
        "fontStyle": "bold"
      }
    },

    {
      "name": "Variable",
      "scope": "variable",
      "settings": {
        "foreground": "#9CDCFE"
      }
    },
    {
      "name": "Variable Object / Readwrite",
      "scope": [
        "variable.other.object",
        "variable.other.readwrite",
        "support.variable.property.ts",
        "meta.object-literal.key.ts",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#D4E4FF"
      }
    },
    {
      "name": "Variable Language (this, self, super)",
      "scope": "variable.language",
      "settings": {
        "foreground": "#56B4E9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable Parameter",
      "scope": "variable.parameter",
      "settings": {
        "foreground": "#E5B567",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable Property",
      "scope": [
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#9CDCFE"
      }
    },

    {
      "name": "Keyword",
      "scope": "keyword",
      "settings": {
        "foreground": "#B28BFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword Control (if, else, for, while, return)",
      "scope": "keyword.control",
      "settings": {
        "foreground": "#B28BFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword Control Import/Export",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": {
        "foreground": "#B28BFF",
        "fontStyle": "italic bold"
      }
    },
    {
      "name": "Keyword Operator",
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#A8C4FF"
      }
    },
    {
      "name": "Keyword Operator Arithmetic",
      "scope": "keyword.operator.arithmetic",
      "settings": {
        "foreground": "#DCDCAA"
      }
    },
    {
      "name": "Keyword Operator Assignment",
      "scope": "keyword.operator.assignment",
      "settings": {
        "foreground": "#D4E4FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword Operator Logical",
      "scope": "keyword.operator.logical",
      "settings": {
        "foreground": "#B28BFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword Operator Comparison",
      "scope": "keyword.operator.comparison",
      "settings": {
        "foreground": "#A8C4FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword Operator New / Delete / Typeof",
      "scope": [
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.instanceof",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#B28BFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword Operator Spread/Rest",
      "scope": "keyword.operator.spread",
      "settings": {
        "foreground": "#D4A0FF"
      }
    },
    {
      "name": "Keyword Other HTTP",
      "scope": "keyword.other.http",
      "settings": {
        "foreground": "#56B4E9"
      }
    },

    {
      "name": "Storage",
      "scope": "storage",
      "settings": {
        "foreground": "#B28BFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage Type (let, const, var, class, function)",
      "scope": "storage.type",
      "settings": {
        "foreground": "#56B4E9",
        "fontStyle": "italic bold"
      }
    },
    {
      "name": "Storage Modifier (public, private, static, async)",
      "scope": "storage.modifier",
      "settings": {
        "foreground": "#B28BFF",
        "fontStyle": "italic"
      }
    },

    {
      "name": "Function Name",
      "scope": "entity.name.function",
      "settings": {
        "foreground": "#DCDCAA"
      }
    },
    {
      "name": "Method Name",
      "scope": [
        "entity.name.function.member",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#DCDCAA"
      }
    },
    {
      "name": "Class Name",
      "scope": [
        "entity.name.class",
        "entity.name.type.class"
      ],
      "settings": {
        "foreground": "#56B4E9",
        "fontStyle": "underline bold"
      }
    },
    {
      "name": "Inherited Class",
      "scope": "entity.other.inherited-class",
      "settings": {
        "foreground": "#56B4E9",
        "fontStyle": "italic underline"
      }
    },
    {
      "name": "Interface / Type Alias",
      "scope": [
        "entity.name.type.interface",
        "entity.name.type.alias"
      ],
      "settings": {
        "foreground": "#56B4E9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Enum Name",
      "scope": "entity.name.type.enum",
      "settings": {
        "foreground": "#56B4E9",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Namespace / Module",
      "scope": [
        "entity.name.namespace",
        "entity.name.type.module"
      ],
      "settings": {
        "foreground": "#56B4E9"
      }
    },
    {
      "name": "Type Parameter (Generics <T>)",
      "scope": [
        "entity.name.type.parameter",
        "meta.type.parameters entity.name.type"
      ],
      "settings": {
        "foreground": "#CC79A7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Tag Name (HTML/XML/JSX)",
      "scope": "entity.name.tag",
      "settings": {
        "foreground": "#56B4E9",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Tag Attribute",
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#DCDCAA",
        "fontStyle": "italic"
      }
    },
    {
      "name": "JSX/TSX Component",
      "scope": [
        "support.class.component.tsx",
        "support.class.component.jsx"
      ],
      "settings": {
        "foreground": "#56B4E9",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Entity Label",
      "scope": "entity.name.label",
      "settings": {
        "foreground": "#E5B567"
      }
    },

    {
      "name": "Library Function",
      "scope": "support.function",
      "settings": {
        "foreground": "#DCDCAA"
      }
    },
    {
      "name": "Library Constant",
      "scope": "support.constant",
      "settings": {
        "foreground": "#D4A0FF"
      }
    },
    {
      "name": "Library Class / Type",
      "scope": [
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#56B4E9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Library Variable",
      "scope": [
        "support.other.variable",
        "support.variable"
      ],
      "settings": {
        "foreground": "#9CDCFE"
      }
    },

    {
      "name": "Decorator / Annotation",
      "scope": [
        "meta.decorator",
        "meta.decorator entity.name.function",
        "punctuation.decorator",
        "storage.type.annotation"
      ],
      "settings": {
        "foreground": "#CC79A7",
        "fontStyle": "italic"
      }
    },

    {
      "name": "Type Annotation",
      "scope": [
        "meta.type.annotation",
        "meta.return.type",
        "entity.name.type"
      ],
      "settings": {
        "foreground": "#56B4E9"
      }
    },

    {
      "name": "Punctuation",
      "scope": [
        "punctuation.accessor",
        "meta.brace.round",
        "meta.brace.square",
        "meta.brace.curly",
        "punctuation.separator.comma",
        "punctuation.terminator.statement",
        "punctuation.separator",
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.definition.array"
      ],
      "settings": {
        "foreground": "#D4E4FF"
      }
    },
    {
      "name": "Punctuation String Delimiters",
      "scope": [
        "punctuation.definition.string.begin",
        "punctuation.definition.string.end"
      ],
      "settings": {
        "foreground": "#E6C07B"
      }
    },

    {
      "name": "Invalid",
      "scope": "invalid",
      "settings": {
        "foreground": "#0B1026",
        "background": "#E69F00",
        "fontStyle": "bold underline"
      }
    },
    {
      "name": "Invalid Deprecated",
      "scope": "invalid.deprecated",
      "settings": {
        "foreground": "#D4E4FF",
        "background": "#B28BFF",
        "fontStyle": "italic underline"
      }
    },

    {
      "name": "Meta Embedded",
      "scope": "meta.embedded",
      "settings": {
        "foreground": "#D4E4FF"
      }
    },

    {
      "name": "JSON Key",
      "scope": [
        "support.type.property-name.json",
        "meta.structure.dictionary.key.json string.quoted.double.json"
      ],
      "settings": {
        "foreground": "#56B4E9"
      }
    },
    {
      "name": "JSON String Value",
      "scope": [
        "meta.structure.dictionary.value.json string.quoted.double.json",
        "meta.structure.dictionary.json string.quoted.double.json"
      ],
      "settings": {
        "foreground": "#E6C07B"
      }
    },

    {
      "name": "YAML Key",
      "scope": "entity.name.tag.yaml",
      "settings": {
        "foreground": "#56B4E9"
      }
    },

    {
      "name": "CSS Property Name",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss",
        "support.type.property-name.less"
      ],
      "settings": {
        "foreground": "#9CDCFE"
      }
    },
    {
      "name": "CSS Property Value",
      "scope": [
        "support.constant.property-value.css",
        "support.constant.property-value.scss"
      ],
      "settings": {
        "foreground": "#E6C07B"
      }
    },
    {
      "name": "CSS Selector / ID / Class",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.name.tag.css"
      ],
      "settings": {
        "foreground": "#DCDCAA"
      }
    },
    {
      "name": "CSS Units",
      "scope": "keyword.other.unit.css",
      "settings": {
        "foreground": "#D4A0FF"
      }
    },
    {
      "name": "CSS Pseudo-class / Pseudo-element",
      "scope": [
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#CC79A7",
        "fontStyle": "italic"
      }
    },

    {
      "name": "Python Decorator",
      "scope": [
        "entity.name.function.decorator.python",
        "meta.function.decorator.python"
      ],
      "settings": {
        "foreground": "#CC79A7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python Self / Cls",
      "scope": [
        "variable.parameter.function.language.special.self.python",
        "variable.parameter.function.language.special.cls.python"
      ],
      "settings": {
        "foreground": "#56B4E9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python F-string",
      "scope": "meta.fstring.python",
      "settings": {
        "foreground": "#E6C07B"
      }
    },

    {
      "name": "Go Package Name",
      "scope": "entity.name.package.go",
      "settings": {
        "foreground": "#56B4E9"
      }
    },

    {
      "name": "Rust Lifetime",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#CC79A7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust Macro",
      "scope": "entity.name.function.macro.rust",
      "settings": {
        "foreground": "#DCDCAA",
        "fontStyle": "bold"
      }
    },

    {
      "name": "Shell Variable",
      "scope": [
        "variable.other.normal.shell",
        "variable.other.special.shell",
        "variable.other.positional.shell"
      ],
      "settings": {
        "foreground": "#9CDCFE"
      }
    },

    {
      "name": "Diff Header",
      "scope": "meta.diff, meta.diff.header",
      "settings": {
        "foreground": "#6B7D94"
      }
    },
    {
      "name": "Diff Deleted",
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#E69F00",
        "background": "#E69F0022"
      }
    },
    {
      "name": "Diff Inserted",
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#56B4E9",
        "background": "#56B4E922"
      }
    },
    {
      "name": "Diff Changed",
      "scope": "markup.changed",
      "settings": {
        "foreground": "#F0E442"
      }
    },

    {
      "scope": "constant.numeric.line-number.find-in-files - match",
      "settings": {
        "foreground": "#D4A0FFA0"
      }
    },
    {
      "scope": "entity.name.filename.find-in-files",
      "settings": {
        "foreground": "#E6C07B"
      }
    },

    {
      "name": "Markdown Heading",
      "scope": [
        "heading.1.markdown",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#56B4E9",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": "markup.bold.markdown",
      "settings": {
        "foreground": "#E8F0FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": "markup.italic.markdown",
      "settings": {
        "foreground": "#E8F0FF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Underline / Link",
      "scope": [
        "markup.underline",
        "markup.underline.link.markdown"
      ],
      "settings": {
        "foreground": "#56B4E9",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown Inline Code",
      "scope": "markup.inline.raw.string.markdown",
      "settings": {
        "foreground": "#DCDCAA"
      }
    },
    {
      "name": "Markdown Code Block",
      "scope": [
        "markup.fenced_code.block.markdown",
        "markup.raw.block.markdown"
      ],
      "settings": {
        "foreground": "#D4E4FF"
      }
    },
    {
      "name": "Markdown Quote",
      "scope": "markup.quote.markdown",
      "settings": {
        "foreground": "#6B7D94",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown List Marker",
      "scope": "punctuation.definition.list.begin.markdown",
      "settings": {
        "foreground": "#D4A0FF"
      }
    },
    {
      "name": "Markdown Image / Link",
      "scope": [
        "meta.image.inline.markdown",
        "meta.link.inline.markdown"
      ],
      "settings": {
        "foreground": "#E6C07B"
      }
    },
    {
      "name": "Markdown Separator",
      "scope": "meta.separator.markdown",
      "settings": {
        "foreground": "#6B7D94"
      }
    },

    {
      "name": "SQL Keyword",
      "scope": [
        "keyword.other.sql",
        "keyword.other.DML.sql"
      ],
      "settings": {
        "foreground": "#B28BFF",
        "fontStyle": "bold"
      }
    },

    {
      "name": "meta.var.expr",
      "scope": "meta.var.expr.js",
      "settings": {
        "foreground": "#D4E4FF"
      }
    }
  ],
  "colors": {
    "foreground": "#D4E4FF",
    "icon.foreground": "#56B4E9",
    "contrastBorder": "#1A2E5575",

    "editor.foreground": "#D4E4FF",
